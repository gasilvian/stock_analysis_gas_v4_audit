{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sws-snowflake-engine/output-schema-v3.1.json",
  "title": "SWS Snowflake Engine Company Output v3.1",
  "type": "object",
  "required": [
    "ticker",
    "exchange",
    "valuation_date",
    "provider_profile",
    "valuation_model",
    "valuation_variant",
    "scores",
    "checks",
    "lineage",
    "warnings"
  ],
  "properties": {
    "ticker": {
      "type": "string"
    },
    "exchange": {
      "type": "string"
    },
    "valuation_date": {
      "type": "string",
      "format": "date"
    },
    "provider_profile": {
      "type": "string",
      "enum": [
        "sws_public_faithful_manual_inputs",
        "yfinance_pragmatic"
      ]
    },
    "valuation_model": {
      "type": "string",
      "enum": [
        "two_stage_fcf",
        "ddm",
        "excess_returns",
        "affo_dcf"
      ]
    },
    "valuation_variant": {
      "type": "string",
      "enum": [
        "base",
        "ffo_fallback",
        "nav_fallback",
        "manual_input",
        "unknown"
      ]
    },
    "valuation_model_source_class": {
      "type": "string",
      "enum": [
        "E0",
        "E1",
        "E2",
        "E3",
        "E4"
      ]
    },
    "fair_value": {
      "type": [
        "number",
        "null"
      ]
    },
    "price": {
      "type": [
        "number",
        "null"
      ]
    },
    "discount_pct": {
      "type": [
        "number",
        "null"
      ]
    },
    "scores": {
      "type": "object",
      "properties": {
        "value": {
          "$ref": "#/$defs/axis_score"
        },
        "future": {
          "$ref": "#/$defs/axis_score"
        },
        "past": {
          "$ref": "#/$defs/axis_score"
        },
        "health": {
          "$ref": "#/$defs/axis_score"
        },
        "dividend": {
          "$ref": "#/$defs/axis_score"
        }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check_result"
      }
    },
    "lineage": {
      "$ref": "#/$defs/lineage"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "axis_score": {
      "type": "object",
      "required": [
        "score_raw",
        "known_checks_count",
        "unknown_checks_count",
        "coverage_pct"
      ],
      "properties": {
        "score_raw": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "known_checks_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "unknown_checks_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "coverage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "check_result": {
      "type": "object",
      "required": [
        "axis",
        "id",
        "name",
        "result",
        "reason_code",
        "source_quality",
        "source_class",
        "inputs",
        "threshold",
        "input_lineage"
      ],
      "properties": {
        "axis": {
          "type": "string",
          "enum": [
            "value",
            "future",
            "past",
            "health",
            "dividend",
            "management"
          ]
        },
        "id": {
          "type": [
            "integer",
            "string"
          ]
        },
        "name": {
          "type": "string"
        },
        "result": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "UNKNOWN"
          ]
        },
        "reason_code": {
          "type": "string"
        },
        "source_quality": {
          "type": "string",
          "enum": [
            "exact",
            "approximation",
            "assumption",
            "missing"
          ]
        },
        "source_class": {
          "type": "string",
          "enum": [
            "E0",
            "E1",
            "E2",
            "E3",
            "E4"
          ]
        },
        "inputs": {
          "type": "object"
        },
        "threshold": {
          "type": "string"
        },
        "input_lineage": {
          "type": "object"
        }
      }
    },
    "lineage": {
      "type": "object",
      "properties": {
        "price_as_of": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "financials_as_of": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "analyst_estimates_as_of": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "fx_as_of": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "industry_averages_as_of": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "assumptions_as_of": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "provider_versions": {
          "type": "object"
        }
      }
    }
  }
}