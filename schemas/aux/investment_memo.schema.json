{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Investment Research Audit Memo v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "sprint",
    "status",
    "reason_code",
    "ticker",
    "valuation_date",
    "memo_type",
    "component_status",
    "sections",
    "unknown_summary",
    "manual_review_items",
    "recommendation_language_absent",
    "recommendation_guardrail",
    "false_precision_guardrail",
    "source_quality",
    "source_class",
    "input_lineage",
    "not_investment_advice"
  ],
  "properties": {
    "schema_version": {"const": "investment_memo.v0.1"},
    "sprint": {"const": "v4.0-p0.11"},
    "status": {"enum": ["PASS", "PASS_WITH_LIMITATIONS", "UNKNOWN", "FAIL"]},
    "reason_code": {"type": "string", "minLength": 1},
    "ticker": {"type": "string", "minLength": 1},
    "exchange": {"type": ["string", "null"]},
    "valuation_date": {"type": ["string", "null"]},
    "memo_type": {"type": "string", "minLength": 1},
    "mode": {"type": "string"},
    "run_id": {"type": ["string", "null"]},
    "input_snapshot_id": {"type": ["string", "null"]},
    "assumptions_hash": {"type": ["string", "null"]},
    "provider_profile": {"type": "string"},
    "component_status": {"type": "object"},
    "sections": {"type": "object"},
    "unknown_summary": {"type": "object"},
    "manual_review_items": {"type": "array", "items": {"type": "string"}},
    "recommendation_language_absent": {"const": true},
    "recommendation_guardrail": {"type": "object"},
    "false_precision_guardrail": {"type": "object"},
    "source_quality": {"type": "string"},
    "source_class": {"type": "string"},
    "input_lineage": {"type": "object"},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "not_investment_advice": {"const": true}
  },
  "additionalProperties": true
}
