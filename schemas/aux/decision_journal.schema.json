{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decision Journal Record v0.1",
  "type": "object",
  "required": ["schema_version", "sprint", "status", "reason_code", "ticker", "decision_type", "source_quality", "source_class", "input_lineage", "not_investment_advice"],
  "properties": {
    "schema_version": {"const": "decision_journal.v0.1"},
    "sprint": {"const": "v4.0-p0.9"},
    "status": {"enum": ["PASS", "UNKNOWN", "FAIL"]},
    "reason_code": {"type": "string", "minLength": 1},
    "decision_id": {"type": ["string", "null"]},
    "created_at": {"type": ["string", "null"]},
    "date": {"type": ["string", "null"]},
    "ticker": {"type": "string", "minLength": 1},
    "decision_type": {"type": "string"},
    "thesis_snapshot_ref": {"type": ["string", "null"]},
    "expected_outcome": {"type": ["string", "null"]},
    "review_date": {"type": ["string", "null"]},
    "notes": {"type": ["string", "null"]},
    "run_id_at_decision": {"type": ["string", "integer", "null"]},
    "data_confidence_at_decision": {"type": ["string", "null"]},
    "model_applicability_at_decision": {"type": ["string", "null"]},
    "conclusion_risk_at_decision": {"type": ["string", "null"]},
    "thesis_status_at_decision": {"type": ["string", "null"]},
    "manual_review_items_at_decision": {"type": "array", "items": {"type": "string"}},
    "post_mortem": {"type": "object"},
    "source_quality": {"type": "string"},
    "source_class": {"type": "string"},
    "input_lineage": {"type": "object"},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "not_investment_advice": {"const": true}
  },
  "additionalProperties": true
}
