{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portfolio Audit v0.1",
  "type": "object",
  "required": ["schema_version", "sprint", "status", "reason_code", "portfolio_id", "holdings_count", "weighted_data_confidence", "weighted_conclusion_risk", "unknown_exposure", "holdings", "manual_review_items", "source_quality", "source_class", "input_lineage", "not_investment_advice"],
  "properties": {
    "schema_version": {"const": "portfolio_audit.v0.1"},
    "sprint": {"const": "v4.0-p0.10"},
    "status": {"enum": ["PASS", "PASS_WITH_LIMITATIONS", "UNKNOWN", "FAIL"]},
    "reason_code": {"type": "string", "minLength": 1},
    "portfolio_id": {"type": "string", "minLength": 1},
    "valuation_date": {"type": ["string", "null"]},
    "holdings_count": {"type": "integer", "minimum": 0},
    "invested_holdings_count": {"type": "integer", "minimum": 0},
    "total_weight_pct": {"type": "number"},
    "cash_weight_pct": {"type": "number"},
    "weighted_data_confidence": {"type": "object"},
    "weighted_conclusion_risk": {"type": "object"},
    "unknown_exposure": {"type": "object"},
    "provider_degradation_exposure": {"type": "object"},
    "sector_concentration": {"type": "object"},
    "factor_concentration": {"type": "object"},
    "macro_sensitivity_map": {"type": "object"},
    "single_thesis_concentration": {"type": "object"},
    "attribution_lite": {"type": "object"},
    "holdings": {"type": "array", "items": {"type": "object"}},
    "manual_review_items": {"type": "array", "items": {"type": "string"}},
    "source_quality": {"type": "string"},
    "source_class": {"type": "string"},
    "input_lineage": {"type": "object"},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "not_investment_advice": {"const": true}
  },
  "additionalProperties": true
}
