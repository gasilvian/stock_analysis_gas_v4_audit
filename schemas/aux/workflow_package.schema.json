{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.sws-engine/schemas/aux/workflow_package.schema.json",
  "title": "SWS v4 P0.13 Research Workflow Package",
  "type": "object",
  "required": [
    "schema_version",
    "sprint",
    "status",
    "reason_code",
    "workflow_id",
    "ticker",
    "run_id",
    "component_status",
    "workflow_steps",
    "readiness_summary",
    "unknown_summary",
    "manual_review_items",
    "api_wiring",
    "dashboard_surfaces",
    "input_lineage",
    "recommendation_language_absent",
    "not_investment_advice"
  ],
  "properties": {
    "schema_version": {"const": "workflow_package.v0.1"},
    "sprint": {"const": "v4.0-p0.13"},
    "status": {"enum": ["PASS", "PASS_WITH_LIMITATIONS", "UNKNOWN", "FAIL"]},
    "reason_code": {"type": "string", "minLength": 1},
    "workflow_id": {"type": "string", "minLength": 1},
    "ticker": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "mode": {"type": "string"},
    "generated_at": {"type": "string"},
    "component_status": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component_id", "label", "required", "status", "reason_code", "unknown_indicators_count", "api_method", "api_path", "dashboard_surface", "manual_review_required"],
        "properties": {
          "component_id": {"type": "string"},
          "label": {"type": "string"},
          "required": {"type": "boolean"},
          "status": {"enum": ["READY", "MISSING_REQUIRED", "MISSING_OPTIONAL", "UNKNOWN_PRESENT"]},
          "reason_code": {"type": "string"},
          "unknown_indicators_count": {"type": "integer", "minimum": 0},
          "api_method": {"type": "string"},
          "api_path": {"type": "string"},
          "dashboard_surface": {"type": "string"},
          "manual_review_required": {"type": "boolean"}
        }
      }
    },
    "workflow_steps": {"type": "array", "items": {"type": "object"}},
    "readiness_summary": {
      "type": "object",
      "required": ["ready_count", "missing_required_count", "missing_optional_count", "unknown_component_count", "manual_review_count", "ready_for_deep_dive", "ready_for_memo"],
      "properties": {
        "ready_count": {"type": "integer", "minimum": 0},
        "missing_required_count": {"type": "integer", "minimum": 0},
        "missing_optional_count": {"type": "integer", "minimum": 0},
        "unknown_component_count": {"type": "integer", "minimum": 0},
        "manual_review_count": {"type": "integer", "minimum": 0},
        "total_unknown_indicators": {"type": "integer", "minimum": 0},
        "ready_for_deep_dive": {"type": "boolean"},
        "ready_for_memo": {"type": "boolean"}
      }
    },
    "unknown_summary": {
      "type": "object",
      "required": ["total_unknown_indicators", "components_with_unknown", "critical_missing_inputs", "critical_missing_inputs_count"],
      "properties": {
        "total_unknown_indicators": {"type": "integer", "minimum": 0},
        "components_with_unknown": {"type": "array", "items": {"type": "string"}},
        "critical_missing_inputs": {"type": "array", "items": {"type": "string"}},
        "critical_missing_inputs_count": {"type": "integer", "minimum": 0}
      }
    },
    "manual_review_items": {"type": "array", "items": {"type": "string"}},
    "api_wiring": {"type": "object"},
    "dashboard_surfaces": {"type": "array", "items": {"type": "object"}},
    "input_lineage": {"type": "array", "items": {"type": "object"}},
    "recommendation_language_absent": {"type": "boolean"},
    "recommendation_guardrail": {"type": "object"},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "not_investment_advice": {"const": true}
  },
  "additionalProperties": true
}
