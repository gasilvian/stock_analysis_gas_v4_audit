# API / engine
SWS_API_AUTH_ENABLED=false
SWS_API_KEY=
SWS_DB_PATH=data/sws.db
SWS_ASSUMPTIONS_PATH=config/assumptions.yaml
SWS_SCHEMA_PATH=schemas/output_schema.json
SWS_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Dashboard
DASHBOARD_API_URL=http://api:8000
DASHBOARD_API_KEY=
DASHBOARD_TIMEOUT_SECONDS=30

# Ops / EOD refresh
SWS_LOGS_DIR=logs
SWS_WATCHLIST=data/watchlists/watchlist_synthetic.csv
SWS_UNIVERSE=data/universe/universe_US-SYN.csv
SWS_MARKET=US-SYN
SWS_PROVIDER_MODE=recorded

# Optional tests: opt-in only
SWS_RUN_LIVE_TESTS=0
SWS_RUN_E2E_TESTS=0
SWS_LIVE_MARKET_DATA_ENABLED=false
